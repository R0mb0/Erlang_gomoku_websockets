%% --- OTP Application Resource File ---
%% This file tells the Erlang VM how to start our entire application.

{application, gomoku_backend,
 [{description, "Distributed Gomoku Engine with WebSockets"},
  {vsn, "0.1.0"},
  {registered, []},
  %% Tell the VM which module contains the startup logic
  {mod, {gomoku_backend_app, []}},
  {applications,
   [kernel,
    stdlib,
    %% We need to ensure Cowboy and JSX start before our app
    cowboy,
    jsx
   ]},
  {env,[]},
  {modules, []}
 ]}.